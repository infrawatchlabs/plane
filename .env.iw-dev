# InfraWatch — Root env for docker-compose.iw-dev.yml (Orbstack)
# Copy to .env before running: cp .env.iw-dev .env

# Database
POSTGRES_USER=plane
POSTGRES_PASSWORD=plane
POSTGRES_DB=plane

# Redis
REDIS_HOST=iw-redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=iw-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=plane
RABBITMQ_VHOST=plane

# Minio / S3
AWS_REGION=
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=secret-key
AWS_S3_ENDPOINT_URL=http://iw-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880

# Minio SSL
MINIO_ENDPOINT_SSL=0
USE_MINIO=1

# Proxy — not needed with Orbstack but kept for compose compat
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

# API key rate limit
API_KEY_RATE_LIMIT=60/minute
